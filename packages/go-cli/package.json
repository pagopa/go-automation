{
  "name": "@go-automation/go-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "GO Automation CLI - Centralized Control Plane",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "go-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo node_modules",
    "dev": "tsx src/index.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "pnpm build && node dist/index.js",
    "watch": "tsc --watch"
  },
  "keywords": [
    "cli",
    "automation",
    "go-automation"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.28.0"
  },
  "dependencies": {
    "@go-automation/go-common": "workspace:*",
    "commander": "catalog:",
    "fuse.js": "catalog:",
    "glob": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
