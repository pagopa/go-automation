{
  "name": "@go-automation/go-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "GO Automation CLI - Centralized Control Plane",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "go-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "echo 'No tests yet'",
    "dev": "node --import tsx/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "automation",
    "go-automation"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.28.0"
  },
  "dependencies": {
    "@go-automation/go-common": "workspace:*",
    "commander": "^13.1.0",
    "tsx": "^4.19.3",
    "glob": "^11.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1"
  }
}
