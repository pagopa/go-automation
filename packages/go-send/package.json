{
  "name": "@go-automation/go-send",
  "version": "1.0.0",
  "type": "module",
  "description": "SEND (Sistema di Notificazione Digitale) SDK - TypeScript SDK for creating and managing digital and analog notifications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "send",
    "notifications",
    "pagopa",
    "go-automation"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "dependencies": {
    "@go-automation/go-common": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "catalog:"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "catalog:",
    "@types/node": "catalog:"
  }
}
