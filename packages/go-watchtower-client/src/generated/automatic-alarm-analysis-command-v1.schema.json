{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "AutomaticAlarmAnalysisCommandV1",
  "additionalProperties": false,
  "properties": {
    "alarmEvent": {
      "additionalProperties": false,
      "properties": {
        "alarmId": {
          "format": "uuid",
          "type": "string"
        },
        "alarmName": {
          "minLength": 1,
          "type": "string"
        },
        "awsAccountId": {
          "minLength": 1,
          "type": "string"
        },
        "awsRegion": {
          "minLength": 1,
          "type": "string"
        },
        "environmentId": {
          "format": "uuid",
          "type": "string"
        },
        "firedAt": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "productId": {
          "format": "uuid",
          "type": "string"
        }
      },
      "required": [
        "id",
        "productId",
        "environmentId",
        "alarmId",
        "alarmName",
        "firedAt",
        "awsAccountId",
        "awsRegion"
      ],
      "type": "object"
    },
    "executionId": {
      "format": "uuid",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "trigger": {
      "additionalProperties": false,
      "properties": {
        "actorId": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "anyOf": [
            {
              "const": "SLACK_INGESTER",
              "type": "string"
            },
            {
              "const": "WATCHTOWER_UI",
              "type": "string"
            },
            {
              "const": "WATCHTOWER_API",
              "type": "string"
            },
            {
              "const": "RETRY",
              "type": "string"
            }
          ]
        },
        "parentExecutionId": {
          "format": "uuid",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    }
  },
  "required": [
    "schemaVersion",
    "executionId",
    "alarmEvent",
    "trigger"
  ],
  "type": "object"
}
