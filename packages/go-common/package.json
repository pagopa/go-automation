{
  "name": "@go-automation/go-common",
  "version": "1.0.0",
  "type": "module",
  "description": "Libreria condivisa per operazioni AWS comuni utilizzata negli script GO automation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/libs/core/index.d.ts",
      "default": "./dist/libs/core/index.js"
    },
    "./aws": {
      "types": "./dist/libs/aws/index.d.ts",
      "default": "./dist/libs/aws/index.js"
    },
    "./send": {
      "types": "./dist/libs/send/index.d.ts",
      "default": "./dist/libs/send/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "node --import tsx/esm --test 'src/**/__tests__/**/*.test.ts'",
    "test:coverage": "mkdir -p coverage && node --import tsx/esm --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/**/__tests__/**' --test-coverage-lines=${GO_COVERAGE_LINES_THRESHOLD:-90} --test-coverage-branches=${GO_COVERAGE_BRANCHES_THRESHOLD:-80} --test-coverage-functions=${GO_COVERAGE_FUNCTIONS_THRESHOLD:-90} --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout 'src/**/__tests__/**/*.test.ts'",
    "prepare": "pnpm run build",
    "prepublish": "pnpm run build"
  },
  "keywords": [
    "aws",
    "wrapper",
    "athena",
    "sts",
    "dynamodb",
    "sqs",
    "go-automation"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "peerDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1028.0",
    "@aws-sdk/client-cloudwatch": "^3.1028.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1028.0",
    "@aws-sdk/client-dynamodb": "^3.1028.0",
    "@aws-sdk/client-ec2": "^3.1028.0",
    "@aws-sdk/client-ecs": "^3.1029.0",
    "@aws-sdk/client-eventbridge": "^3.1028.0",
    "@aws-sdk/client-kinesis": "^3.1028.0",
    "@aws-sdk/client-kms": "^3.1028.0",
    "@aws-sdk/client-lambda": "^3.1028.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/client-sqs": "^3.1028.0",
    "@aws-sdk/client-ssm": "^3.1028.0",
    "@aws-sdk/client-sts": "^3.1028.0",
    "@aws-sdk/credential-provider-ini": "^3.972.29",
    "@slack/web-api": "^7.15.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1028.0",
    "@aws-sdk/client-dynamodb": "^3.1028.0",
    "@aws-sdk/client-ecs": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/client-sqs": "^3.1028.0",
    "@aws-sdk/client-sts": "^3.1028.0",
    "@aws-sdk/credential-provider-ini": "^3.972.29",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@slack/web-api": "^7.15.0",
    "cli-table3": "^0.6.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "luxon": "^3.7.2",
    "prompts": "^2.4.2",
    "undici": "^8.0.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.2",
    "@types/prompts": "^2.4.9"
  }
}
