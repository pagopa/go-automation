{
  "name": "@go-automation/go-runbook",
  "version": "1.0.0",
  "type": "module",
  "description": "Declarative runbook engine for operational automation with AWS service integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "node --import tsx/esm --test 'src/**/__tests__/**/*.test.ts'",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "go-automation",
    "runbook",
    "operational",
    "automation"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "dependencies": {
    "@go-automation/go-common": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-athena": "catalog:",
    "@aws-sdk/client-cloudwatch": "catalog:",
    "@aws-sdk/client-cloudwatch-logs": "catalog:",
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/util-dynamodb": "catalog:"
  },
  "devDependencies": {
    "@aws-sdk/client-athena": "catalog:",
    "@aws-sdk/client-cloudwatch": "catalog:",
    "@aws-sdk/client-cloudwatch-logs": "catalog:",
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/util-dynamodb": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
