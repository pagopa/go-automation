{
  "name": "go-bot-qe-slack-handler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test-build": "echo 'Skipping CodeBuild packaging for this function'",
    "build": "node esbuild.config.mjs",
    "build:typecheck": "tsc --noEmit",
    "package": "pnpm build && cd ../../artifacts/go-BotQESlackHandler && zip -r ../../functions/go-BotQESlackHandler/function.zip .",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "catalog:"
  },
  "devDependencies": {
    "@types/aws-lambda": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:"
  }
}
