{
  "name": "go-send-monitor-tpp-messages-lambda",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/handler.mjs",
  "scripts": {
    "test-build": "pnpm build && cd ../../artifacts/go-SendMonitorTppMessagesLambda && zip -r ../../functions/go-SendMonitorTppMessagesLambda/function.zip .",
    "build": "node esbuild.config.mjs",
