{
  "name": "go-send-monitor-tpp-messages-lambda",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/handler.mjs",
  "scripts": {
    "test-build": "pnpm build && cd ../../artifacts/go-SendMonitorTppMessagesLambda && zip -r ../../functions/go-SendMonitorTppMessagesLambda/function.zip .",
    "build": "pnpm --filter=send-monitor-tpp-messages build && node esbuild.config.mjs",
    "build:typecheck": "pnpm --filter=send-monitor-tpp-messages build && tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "pnpm build && cd ../../artifacts/go-SendMonitorTppMessagesLambda && zip -r ../../functions/go-SendMonitorTppMessagesLambda/function.zip .",
    "test:local": "pnpm --filter=send-monitor-tpp-messages build && tsx src/test-local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@go-automation/go-common": "workspace:*",
    "send-monitor-tpp-messages": "workspace:*"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  }
}
