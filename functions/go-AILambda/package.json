{
  "name": "go-ai-lambda",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test-build": "echo 'Skipping CodeBuild packaging for this function'",
    "build": "node esbuild.config.mjs",
    "build:typecheck": "tsc --noEmit",
    "package": "pnpm build && cd ../../artifacts/go-AILambda && zip -r ../../functions/go-AILambda/function.zip .",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "catalog:",
    "@aws-sdk/credential-provider-ini": "catalog:",
    "@go-automation/go-ai": "workspace:*"
  },
  "devDependencies": {
    "@types/aws-lambda": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:"
  }
}
