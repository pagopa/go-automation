{
  "name": "go-send-monitor-athena-query-lambda",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/handler.mjs",
  "description": "Lambda",
  "scripts": {
    "test-build": "pnpm build && cd ../../artifacts/go-SendMonitorAthenaQueryLambda && zip -r ../../functions/go-SendMonitorAthenaQueryLambda/function.zip .",
    "build": "pnpm --filter=send-monitor-athena-query build && node esbuild.config.mjs",
    "build:typecheck": "pnpm --filter=send-monitor-athena-query build && tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "pnpm build && cd ../../artifacts/go-SendMonitorAthenaQueryLambda && zip -r ../../functions/go-SendMonitorAthenaQueryLambda/function.zip .",
    "test:local": "pnpm --filter=send-monitor-athena-query build && tsx src/test-local.ts"
  },
  "dependencies": {
    "@go-automation/go-common": "workspace:*",
    "send-monitor-athena-query": "workspace:*"
  },
  "devDependencies": {
    "@types/aws-lambda": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "tsx": "catalog:"
  }
}
