# Copy to .env.deploy, replace placeholders, then run: set -a; source .env.deploy; set +a
AWS_PROFILE=<monitoring-profile>
DEPLOY_KIND=monitoring
DEPLOY_ENV=dev
DEPLOY_REGION=eu-south-1
WATCHTOWER_INTERNAL_URL=https://<watchtower-internal-host>
WATCHTOWER_VPC_ID=vpc-...
WATCHTOWER_PRIVATE_SUBNET_ID=subnet-...
WATCHTOWER_NAT_GATEWAY_ID=nat-...
EXECUTE_RUNBOOK_WORKER_SUBNET_CIDR=172.31.65.0/24
EXECUTE_RUNBOOK_WORKER_SUBNET_AZ=eu-south-1b
WATCHTOWER_SLACK_INGESTOR_ROLE_ARN=arn:aws:iam::<account>:role/<role>
WATCHTOWER_BACKEND_ROLE_ARN=arn:aws:iam::<account>:role/<role>
# Optional. If omitted, SST creates the secret metadata and outputs its ARN.
WATCHTOWER_SERVICE_PRINCIPAL_SECRET_ARN=arn:aws:secretsmanager:eu-south-1:<account>:secret:<name>
OAM_SOURCE_ACCOUNT_IDS=<source-account-1>,<source-account-2>
