# Set log level to silent to reduce output noise
#loglevel=silent

# Use silent reporter to minimize output (for PNPM)
#reporter=silent

# Usa symlinks per workspace dependencies (default pnpm)
enable-pre-post-scripts=true

# Auto install peers
auto-install-peers=true

# Strict peer dependencies
strict-peer-dependencies=false

# Hoist pattern per evitare duplicati
shamefully-hoist=false

# Public hoist pattern (AWS SDK può essere hoisted)
public-hoist-pattern[]=*aws-sdk*

# Inject workspace packages (pnpm 10+ nuova modalità)
# Copia i pacchetti workspace invece di usare symlink
# Necessario per: pnpm deploy, artifacts standalone
inject-workspace-packages=true