{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "validate-scaffold configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["groups"],
  "properties": {
    "$schema": { "type": "string" },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/group" }
    }
  },
  "$defs": {
    "ruleSet": {
      "type": "string",
      "enum": ["monorepo", "scripts", "functions"]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^(\\/|\\\\)" },
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)" }
        ]
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ruleSet"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ruleSet": { "$ref": "#/$defs/ruleSet" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/relativePath" }
        },
        "include": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/relativePath" }
        },
        "exclude": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" },
          "default": []
        }
      },
      "oneOf": [{ "required": ["paths"] }, { "required": ["include"] }]
    }
  }
}
