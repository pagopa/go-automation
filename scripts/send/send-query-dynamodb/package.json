{
  "name": "send-query-dynamodb",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Script per recupero dati da una tabella DynamoDB",
  "main": "dist/index.js",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
