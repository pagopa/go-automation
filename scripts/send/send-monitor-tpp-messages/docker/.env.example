# =============================================================================
# Environment Variables - send-monitor-tpp-messages
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
#
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
IMAGE_TAG=latest
TZ=Europe/Rome

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
# AWS SSO Profile (for local development with SSO)
AWS_PROFILE=

# Environment identifier (dev, uat, prod)
AWS_ENVIRONMENT=prod

# AWS Region
AWS_REGION=eu-south-1

# -----------------------------------------------------------------------------
# Athena Configuration
# -----------------------------------------------------------------------------
# Athena database name
ATHENA_DATABASE=

# Athena catalog (usually AwsDataCatalog)
ATHENA_CATALOG=AwsDataCatalog

# Athena workgroup
ATHENA_WORKGROUP=primary

# S3 location for Athena query results
ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# Query retry configuration
ATHENA_MAX_RETRIES=60
ATHENA_RETRY_DELAY=10000

# -----------------------------------------------------------------------------
# Slack Configuration
# -----------------------------------------------------------------------------
# Slack Bot OAuth Token (xoxb-...)
SLACK_TOKEN=

# Slack channel for reports (channel ID or #channel-name)
SLACK_CHANNEL=

# Optional: Custom message template
SLACK_MESSAGE_TEMPLATE=

# -----------------------------------------------------------------------------
# Scheduling Configuration (only for cron mode)
# -----------------------------------------------------------------------------
# Cron schedule format: MIN HOUR DAY MONTH WEEKDAY
# Default: Run at 09:00, 11:00, 15:00, 17:00 every day
CRON_SCHEDULE=0 9,11,15,17 * * *
