{
  "name": "send-monitor-tpp-messages",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Monitor TPP messages via Athena queries and generate reports with optional Slack notifications",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js",
    "./main": "./dist/main.js",
    "./libs": "./dist/libs/index.js",
    "./types": "./dist/types/index.js"
  },
  "files": [
    "dist",
    "configs"
  ],
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node dist/index.js",
    "start:cron": "node dist/cron.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "athena",
    "aws",
    "csv",
    "slack",
    "report",
    "typescript",
    "tpp",
    "send"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-athena": "^3.1030.0",
    "@aws-sdk/credential-provider-ini": "^3.972.29",
    "@go-automation/go-common": "workspace:*",
    "@slack/web-api": "^7.15.1",
    "croner": "^10.0.1",
    "luxon": "^3.7.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.2"
  }
}
