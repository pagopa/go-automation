    "docker:run": "docker compose run --rm app",
    "docker:dry-run": "./docker-run.sh dry-run",
    "docker:shell": "docker compose run --rm app /bin/sh",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "send",
    "notifications",
    "import",
    "csv",
