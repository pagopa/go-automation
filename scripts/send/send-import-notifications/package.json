{
  "name": "send-import-notifications",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Script di importazione notifiche SEND da CSV con upload documenti e polling IUN",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node dist/index.js",
    "dev": "NODE_EXTRA_CA_CERTS=/Users/massimo/Desktop/Proxyman.pem tsx src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
