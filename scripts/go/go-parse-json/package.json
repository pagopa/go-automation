{
  "name": "go-parse-json",
  "version": "1.1.0",
  "private": true,
  "description": "Extract fields from JSON/NDJSON files with path-first and recursive fallback",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "pnpm build && node dist/index.js",
    "lint": "eslint src",
    "watch": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "go",
    "json"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "dependencies": {
    "@go-automation/go-common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
