{
  "name": "go-parse-json",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Parses JSON files - Extracts nested fields from JSON/NDJSON data via recursive path matching.",
  "main": "dist/index.js",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo node_modules",
    "dev": "tsx src/index.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "pnpm build && node dist/index.js",
    "watch": "tsc --watch"
  },
  "keywords": [
    "go",
    "json"
  ],
  "author": "Team GO - Gestione Operativa",
  "license": "ISC",
  "dependencies": {
    "@go-automation/go-common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
