{
  "name": "go-json-parser",
  "version": "1.0.0",
  "description": "Extract fields from JSON/NDJSON files with path-first and recursive fallback",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "pnpm build && node dist/index.js",
    "lint": "eslint src",
    "watch": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@go-automation/go-common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2"
  }
}
